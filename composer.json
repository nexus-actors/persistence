{
    "name": "nexus-actors/persistence",
    "description": "Nexus persistence — event sourcing and durable state for actors.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.5.7",
        "nexus-actors/core": "^0.1",
        "nexus-actors/serialization": "^0.1",
        "psr/log": "^3.0",
        "symfony/uid": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Monadial\\Nexus\\Persistence\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Monadial\\Nexus\\Persistence\\Tests\\": "tests/"
        }
    }
}
